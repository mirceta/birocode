# .NET build output
**/bin/
**/obj/

# Logs written at runtime
**/logs/
*.log

# Node (also covered by client/.gitignore)
node_modules/
dist/
*.local

# Installer/deployer runtime settings -- holds plaintext access + PFX passwords
settings.json

# Isolated build output for the App-tab self-preview (see CLAUDE.md)
.claudeweb-preview/

# Deploy staging/tooling generated at runtime (parallels .claudeweb-preview)
.claudeweb-deploy/
.selfdev-build/

# Visual Studio per-machine cache (IntelliSense dbs, layout, .suo)
.vs/

# Rollback snapshot of the last-good frontend build (artifact, like dist/)
client/dist.lastgood/

# Chat file uploads (images etc. sent alongside prompts)
.claudeweb-uploads/
.preview-test/

client/dist-preview/
